# Copy to .env in this directory (cp .env.example .env) and set POSTGRES_PASSWORD.
# Compose loads .env automatically for ${POSTGRES_*} in docker-compose.yml.
# Generate a password: openssl rand -base64 32

POSTGRES_USER=app
POSTGRES_PASSWORD=
POSTGRES_DB=readings_db

# For npm start on the host (not the api container), point at loopback-mapped Postgres:
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# docker compose sets POSTGRES_HOST=db for the api service automatically.